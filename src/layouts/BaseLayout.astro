---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromPath, htmlLang, localePath, type Locale } from '../lib/i18n';
import { absoluteUrl, pageTitle, siteConfig, siteDescription, siteName } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  locale?: Locale;
}

const {
  title,
  locale = getLocaleFromPath(Astro.url.pathname),
  description = siteDescription(locale),
  image = siteConfig.defaultImage,
  type = 'website'
} = Astro.props;

const canonicalUrl = absoluteUrl(Astro.url.pathname);
const resolvedTitle = pageTitle(title, locale);
const ogImage = absoluteUrl(image);
const alternateLocale = locale === 'zh' ? 'en' : 'zh';
const alternatePath = localePath(Astro.url.pathname, alternateLocale);
---

<!doctype html>
<html lang={htmlLang(locale)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{resolvedTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={htmlLang(locale)} href={canonicalUrl} />
    <link rel="alternate" hreflang={htmlLang(alternateLocale)} href={absoluteUrl(alternatePath)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:locale" content={siteConfig.ogLocale[locale]} />
    <meta property="og:site_name" content={siteName(locale)} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <div class="site-shell">
      <Header locale={locale} pathname={Astro.url.pathname} />
      <main>
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>
