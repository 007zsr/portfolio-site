---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLocalizedPath, getNavigation, getSiteConfig } from '../lib/content-api';
import type { Locale } from '../lib/i18n';
import { normalizePath } from '../lib/routes';

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const site = getSiteConfig(locale);
const links = getNavigation(locale);
const normalizedPath = normalizePath(pathname);
const homeHref = getLocalizedPath('/', locale);
const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  return normalizedHref === homeHref
    ? normalizedPath === normalizedHref
    : normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);
};
---

<header class="site-header">
  <a class="brand" href={homeHref} aria-label={`${site.shortName} home`}>
    <span class="brand-mark" aria-hidden="true">ZSR</span>
    <span class="brand-text">{site.shortName}</span>
  </a>
  <nav class="primary-nav" aria-label="Primary navigation">
    {
      links.map((link) => (
        <a class:list={['nav-link', { active: isActive(link.href) }]} href={link.href}>
          {link.label}
        </a>
      ))
    }
    <LanguageSwitcher locale={locale} pathname={pathname} />
  </nav>
</header>
