---
import { localePath, t, type Locale } from '../lib/i18n';
import { localizeVideo, type Video } from '../lib/contentItems';
import { getProjectById, localizeProject } from '../lib/projects';
import TechTag from './TechTag.astro';

interface Props {
  video: Video;
  locale: Locale;
}

const { video, locale } = Astro.props;
const item = localizeVideo(video, locale);
const project = video.relatedProjectId ? getProjectById(video.relatedProjectId) : undefined;
const localizedProject = project ? localizeProject(project, locale) : undefined;
---

<article class="content-card video-card">
  <div class="video-thumb" aria-hidden="true">
    <span>▶</span>
  </div>
  <p class="download-type">{video.platform}</p>
  <h3><a href={localePath(`/videos/${video.slug}`, locale)}>{item.title}</a></h3>
  <p class="content-meta">{video.date}</p>
  <p>{item.summary}</p>
{project && localizedProject && <a class="inline-link" href={localePath(`/projects/${project.slug}`, locale)}>{localizedProject.title}</a>}
  <div class="tag-list">
    {video.tags.map((tag) => <TechTag label={tag} />)}
  </div>
  <a class="button secondary" href={video.url === '#' ? localePath(`/videos/${video.slug}`, locale) : video.url}>
    {t(locale, 'button.watchVideo')}
  </a>
</article>
