---
import { localizeDownload, type Download } from '../lib/downloads';
import { localePath, t, type Locale } from '../lib/i18n';
import { localizeProject, type Project } from '../lib/projects';

interface Props {
  download: Download;
  locale: Locale;
  project?: Project;
}

const { download, locale, project } = Astro.props;
const localizedDownload = localizeDownload(download, locale);
const localizedProject = project ? localizeProject(project, locale) : undefined;
const unavailable = !download.url || download.url === '#';
const meta = [
  download.fileType,
  localizedDownload.size,
  download.version,
  download.updatedAt
].filter(Boolean);
---

<article class="download-card">
  <div>
    <p class="download-type">{localizedDownload.category}</p>
    <h3>{localizedDownload.title}</h3>
    <p class="download-meta">{meta.join(' · ')}</p>
    <p class="download-source">{t(locale, 'common.source')}: {download.sourceType.replaceAll('_', ' ')}</p>
    {
      project && localizedProject && (
        <a class="inline-link" href={localePath(`/projects/${project.slug}`, locale)}>
          {t(locale, 'common.relatedProject')}: {localizedProject.title}
        </a>
      )
    }
  </div>
  <div class="download-actions">
    {
      unavailable ? (
        <span class="button button-disabled">{t(locale, 'button.comingSoon')}</span>
      ) : (
        <a class="button" href={download.url} download={download.sourceType === 'local'}>
          {t(locale, 'button.openFile')}
        </a>
      )
    }
  </div>
</article>
