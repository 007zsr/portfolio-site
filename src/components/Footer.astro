---
import { getFooterContent } from '../lib/content-api';
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const footer = getFooterContent(locale);
---

<footer class="site-footer">
  <div>
    <strong>{footer.siteName}</strong>
    <p>{footer.description}</p>
  </div>
  <div class="footer-meta">
    <div class="footer-links">
      {footer.links.map((link) => <a class="inline-link" href={link.href}>{link.label}</a>)}
    </div>
    <span>© {footer.year} Sirui Zhou</span>
  </div>
</footer>
