---
import { getLocalizedPath } from '../lib/content-api';
import { t, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const targetLocale = locale === 'zh' ? 'en' : 'zh';
const targetPath = getLocalizedPath(pathname, targetLocale);
---

<a class="language-switcher" href={targetPath}>{t(locale, 'language.switch')}</a>
