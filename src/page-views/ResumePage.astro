---
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import TechTag from '../components/TechTag.astro';
import awards from '../data/awards.json';
import profile from '../data/profile.json';
import skills from '../data/skills.json';
import { localePath, pick, t, type Locale } from '../lib/i18n';
import { featuredProjects, localizeProject } from '../lib/projects';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Layout locale={locale} title={t(locale, 'nav.resume')} description={t(locale, 'page.resume.desc')}>
  <section class="page-section">
    <SectionTitle eyebrow={t(locale, 'nav.resume')} title={profile.name} description={pick(profile.headline, locale)} />
    <div class="button-row">
      <a class="button" href="/files/resume-placeholder.pdf">{t(locale, 'button.download')}</a>
      <a class="button secondary" href={localePath('/contact', locale)}>{t(locale, 'button.contact')}</a>
    </div>
  </section>

  <section class="page-section tight">
    <div class="grid two">
      <section class="resume-block">
        <h3>{locale === 'zh' ? '教育背景' : 'Education'}</h3>
        <ul class="plain-list">
          {
            profile.education.map((item) => (
              <li>
                <strong>{pick(item.school, locale)}</strong>
                <p>{pick(item.degree, locale)}</p>
                <p>{item.period}</p>
              </li>
            ))
          }
        </ul>
      </section>
      <section class="resume-block">
        <h3>{t(locale, 'nav.contact')}</h3>
        <p>{profile.contact.email}</p>
        <p>{profile.contact.github}</p>
      </section>
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle title={locale === 'zh' ? '项目摘要' : 'Project summary'} />
    <div class="grid two">
      {
        featuredProjects.map((project) => {
          const item = localizeProject(project, locale);
          return (
            <article class="resume-block">
              <h3>{item.title}</h3>
              <p>{item.role} · {project.year} · {item.status}</p>
              <p>{item.summary}</p>
            </article>
          );
        })
      }
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle title={locale === 'zh' ? '技能' : 'Skills'} />
    <div class="grid two">
      {
        skills.map((group) => (
          <section class="resume-block">
            <h3>{pick(group.group, locale)}</h3>
            <div class="tag-list">
              {group.items.map((skill) => <TechTag label={skill} />)}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle title={locale === 'zh' ? '奖项与记录' : 'Awards and notes'} />
    <div class="grid two">
      {
        awards.map((award) => (
          <article class="resume-block">
            <h3>{pick(award.title, locale)}</h3>
            <p>{pick(award.issuer, locale)} · {award.year}</p>
            <p>{pick(award.description, locale)}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
