---
import Layout from '../components/Layout.astro';
import TechTag from '../components/TechTag.astro';
import { localizeLink, type LinkItem } from '../lib/contentItems';
import { localePath, t, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  link: LinkItem;
}

const { locale, link } = Astro.props;
const item = localizeLink(link, locale);
---

<Layout locale={locale} title={item.title} description={item.summary}>
  <section class="detail-hero">
    <p class="eyebrow">{item.category}</p>
    <h1>{item.title}</h1>
    <p class="lead">{item.summary}</p>
    <div class="tag-list">
      {link.tags.map((tag) => <TechTag label={tag} />)}
    </div>
  </section>
  <div class="detail-layout">
    <article class="detail-main">
      <section class="info-panel">
        <h2>{t(locale, 'common.external')}</h2>
        <p>{item.summary}</p>
      </section>
    </article>
    <aside class="detail-aside">
      <a class="button secondary" href={link.url}>{t(locale, 'button.openLink')}</a>
      <a class="inline-link" href={localePath('/links', locale)}>{t(locale, 'nav.links')}</a>
    </aside>
  </div>
</Layout>
