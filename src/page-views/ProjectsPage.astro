---
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { getProjectsContent, getSeoMeta } from '../lib/content-api';
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = getProjectsContent(locale);
const seo = getSeoMeta('projects', locale);
---

<Layout locale={locale} title={seo.title} description={seo.description}>
  <section class="page-section">
    <SectionTitle eyebrow={content.eyebrow} title={content.title} description={content.description} />
    <div class="project-grid">
      {content.projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</Layout>
