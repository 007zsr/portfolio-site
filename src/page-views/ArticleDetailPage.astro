---
import Layout from '../components/Layout.astro';
import TechTag from '../components/TechTag.astro';
import { localizeArticle, type Article } from '../lib/articles';
import { localePath, t, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  article: Article;
}

const { locale, article } = Astro.props;
const item = localizeArticle(article, locale);
const Content = article.Content;
---

<Layout locale={locale} title={item.title} description={item.summary} type="article">
  <section class="detail-hero">
    <p class="eyebrow">{item.category}</p>
    <h1>{item.title}</h1>
    <p class="lead">{item.summary}</p>
    <div class="tag-list">
      {article.tags.map((tag) => <TechTag label={tag} />)}
    </div>
  </section>
  <div class="detail-layout">
    <article class="detail-main">
      <section class="info-panel project-body">
        <Content />
      </section>
    </article>
    <aside class="detail-aside">
      <section class="info-panel">
        <h2>{t(locale, 'common.category')}</h2>
        <div class="meta-row"><span>{t(locale, 'common.date')}</span><span>{article.date}</span></div>
        <div class="meta-row"><span>{t(locale, 'common.status')}</span><span>{item.languageStatus}</span></div>
      </section>
      <a class="inline-link" href={localePath('/articles', locale)}>{t(locale, 'nav.articles')}</a>
    </aside>
  </div>
</Layout>
