---
import DownloadCard from '../components/DownloadCard.astro';
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { localizeDownload, publicDownloads } from '../lib/downloads';
import { t, type Locale } from '../lib/i18n';
import { getProjectById } from '../lib/projects';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const groups = publicDownloads.reduce((acc, download) => {
  const localized = localizeDownload(download, locale);
  acc[localized.category] = acc[localized.category] ?? [];
  acc[localized.category].push(download);
  return acc;
}, {} as Record<string, typeof publicDownloads>);
---

<Layout locale={locale} title={t(locale, 'nav.downloads')} description={t(locale, 'page.downloads.desc')}>
  <section class="page-section">
    <SectionTitle eyebrow={t(locale, 'nav.downloads')} title={t(locale, 'page.downloads.title')} description={t(locale, 'page.downloads.desc')} />
    <div class="download-groups">
      {
        Object.entries(groups).map(([category, items]) => (
          <section class="download-group">
            <h2>{category}</h2>
            <div class="grid">
              {
                items.map((download) => (
                  <DownloadCard
                    download={download}
                    locale={locale}
                    project={download.projectId ? getProjectById(download.projectId) : undefined}
                  />
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </section>
</Layout>
