---
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import TechTag from '../components/TechTag.astro';
import { getHomeContent, getSeoMeta } from '../lib/content-api';
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getHomeContent(locale);
const seo = getSeoMeta('home', locale);
const heroStyle = `--hero-image: url('${home.heroImage}')`;
---

<Layout locale={locale} title={seo.title} description={seo.description}>
  <section class="hero" style={heroStyle}>
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">{home.eyebrow}</p>
        <h1>{home.title}</h1>
        <p>{home.headline}</p>
        <div class="tag-list" aria-label={home.focusLabel}>
          {home.focusTags.map((tag) => <TechTag label={tag} />)}
        </div>
        <div class="hero-actions">
          {
            home.actions.map((action) => (
              <a class:list={['button', { secondary: action.variant === 'secondary' }]} href={action.href}>
                {action.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <SectionTitle
      eyebrow={home.eyebrow}
      title={home.featuredTitle}
      description={home.featuredDescription}
    />
    <div class="project-grid">
      {home.featuredProjects.map((project) => <ProjectCard project={project} compact />)}
    </div>
  </section>
</Layout>
