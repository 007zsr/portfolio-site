---
import DownloadCard from '../components/DownloadCard.astro';
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import StatusBadge from '../components/StatusBadge.astro';
import TechTag from '../components/TechTag.astro';
import { publicDownloads } from '../lib/downloads';
import { localePath, t, type Locale } from '../lib/i18n';
import { getProjectById, localizeProject, type Project } from '../lib/projects';

interface Props {
  locale: Locale;
  project: Project;
}

const { locale, project } = Astro.props;
const localizedProject = localizeProject(project, locale);
const Content = project.Content;
const relatedDownloads = publicDownloads.filter(
  (download) =>
    download.projectId === project.id || project.downloads.includes(download.id)
);
---

<Layout locale={locale} title={localizedProject.title} description={localizedProject.summary} image={project.image} type="article">
  <section class="detail-hero">
    <p class="eyebrow">{localizedProject.category}</p>
    <h1>{localizedProject.title}</h1>
    <p class="lead">{localizedProject.summary}</p>
    <div class="tag-list">
      <StatusBadge status={localizedProject.status} />
      {project.technologies.map((tech) => <TechTag label={tech} />)}
    </div>
  </section>

  <div class="detail-layout">
    <article class="detail-main">
      <img src={project.image} alt={localizedProject.imageAlt} />

      {localizedProject.responsibilities.length > 0 && (
        <section class="info-panel">
          <h2>{t(locale, 'section.responsibilities')}</h2>
          <ul class="plain-list">
            {localizedProject.responsibilities.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      )}

      {localizedProject.features.length > 0 && (
        <section class="info-panel">
          <h2>{t(locale, 'section.features')}</h2>
          <ul class="plain-list">
            {localizedProject.features.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      )}

      {localizedProject.outcomes.length > 0 && (
        <section class="info-panel">
          <h2>{t(locale, 'section.outcomes')}</h2>
          <ul class="plain-list">
            {localizedProject.outcomes.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      )}

      <section class="info-panel project-body">
        <Content />
      </section>

      {relatedDownloads.length > 0 && (
        <section>
          <SectionTitle title={t(locale, 'section.relatedDownloads')} />
          <div class="grid">
            {
              relatedDownloads.map((download) => (
                <DownloadCard download={download} locale={locale} project={getProjectById(download.projectId ?? '')} />
              ))
            }
          </div>
        </section>
      )}
    </article>

    <aside class="detail-aside">
      <section class="info-panel">
        <h2>{t(locale, 'section.projectFacts')}</h2>
        <div class="meta-row"><span>{t(locale, 'common.year')}</span><span>{project.year}</span></div>
        <div class="meta-row"><span>{t(locale, 'common.role')}</span><span>{localizedProject.role}</span></div>
        <div class="meta-row"><span>{t(locale, 'common.status')}</span><span>{localizedProject.status}</span></div>
        <div class="meta-row"><span>{t(locale, 'common.type')}</span><span>{localizedProject.category}</span></div>
      </section>

      {project.links.length > 0 && (
        <section class="info-panel">
          <h2>{t(locale, 'common.links')}</h2>
          <div class="button-row">
            {
              project.links.map((link) =>
                link.url === '#' ? (
                  <span class="button button-disabled">{t(locale, 'button.comingSoon')}</span>
                ) : (
                  <a class="button secondary" href={link.url}>{link.label}</a>
                )
              )
            }
          </div>
        </section>
      )}
      <a class="inline-link" href={localePath('/projects', locale)}>{t(locale, 'nav.projects')}</a>
    </aside>
  </div>
</Layout>
