---
import Layout from '../components/Layout.astro';
import TechTag from '../components/TechTag.astro';
import { localizePaper, type Paper } from '../lib/contentItems';
import { localePath, t, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  paper: Paper;
}

const { locale, paper } = Astro.props;
const item = localizePaper(paper, locale);
---

<Layout locale={locale} title={paper.title} description={item.summary} type="article">
  <section class="detail-hero">
    <p class="eyebrow">{item.topic}</p>
    <h1>{paper.title}</h1>
    <p class="lead">{item.summary}</p>
    <div class="tag-list">
      {paper.tags.map((tag) => <TechTag label={tag} />)}
    </div>
  </section>
  <div class="detail-layout">
    <article class="detail-main">
      <section class="info-panel">
        <h2>{t(locale, 'button.readingNotes')}</h2>
        <p>{item.notes}</p>
      </section>
    </article>
    <aside class="detail-aside">
      <section class="info-panel">
        <h2>{t(locale, 'common.topic')}</h2>
        <div class="meta-row"><span>{t(locale, 'common.authors')}</span><span>{paper.authors.join(', ')}</span></div>
        <div class="meta-row"><span>{t(locale, 'common.year')}</span><span>{paper.year}</span></div>
        <div class="meta-row"><span>{t(locale, 'common.venue')}</span><span>{paper.venue}</span></div>
      </section>
      <div class="button-row">
        {paper.url === '#' ? <span class="button button-disabled">{t(locale, 'button.comingSoon')}</span> : <a class="button secondary" href={paper.url}>{t(locale, 'button.viewPaper')}</a>}
        <a class="inline-link" href={localePath('/papers', locale)}>{t(locale, 'nav.papers')}</a>
      </div>
    </aside>
  </div>
</Layout>
