---
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import TechTag from '../components/TechTag.astro';
import { getAboutContent, getSeoMeta } from '../lib/content-api';
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const about = getAboutContent(locale);
const seo = getSeoMeta('about', locale);
---

<Layout locale={locale} title={seo.title} description={seo.description}>
  <section class="page-section">
    <SectionTitle eyebrow={about.eyebrow} title={about.title} description={about.description} />
    <div class="grid two">
      <section class="info-panel">
        <h3>{about.educationTitle}</h3>
        <ul class="plain-list">
          {
            about.education.map((item) => (
              <li>
                <strong>{item.school}</strong>
                <p>{item.degree}</p>
                <p>{item.period}</p>
                <p>{item.details}</p>
              </li>
            ))
          }
        </ul>
      </section>
      <section class="info-panel">
        <h3>{about.interestsTitle}</h3>
        <ul class="plain-list">
          {about.interests.map((interest) => <li>{interest}</li>)}
        </ul>
      </section>
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle eyebrow={about.skillsEyebrow} title={about.skillsTitle} />
    <div class="grid two">
      {
        about.skills.map((group) => (
          <section class="info-panel">
            <h3>{group.group}</h3>
            <div class="tag-list">
              {group.items.map((skill) => <TechTag label={skill} />)}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle eyebrow={about.experienceEyebrow} title={about.experienceTitle} />
    <div class="grid two">
      {
        about.experience.map((item) => (
          <article class="info-panel">
            <h3>{item.title}</h3>
            <p>{item.issuer} · {item.year}</p>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
