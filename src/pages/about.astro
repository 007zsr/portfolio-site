---
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import TechTag from '../components/TechTag.astro';
import profile from '../data/profile.json';
import skills from '../data/skills.json';
import awards from '../data/awards.json';
---

<Layout
  title="About"
  description="About Sirui Zhou, including education, engineering focus areas, skills, and project experience."
>
  <section class="page-section">
    <SectionTitle
      eyebrow="About"
      title="Applied engineering through working prototypes"
      description={profile.summary}
    />

    <div class="grid two">
      <section class="info-panel">
        <h3>Education</h3>
        <ul class="plain-list">
          {
            profile.education.map((item) => (
              <li>
                <strong>{item.school}</strong>
                <p>{item.degree}</p>
                <p>{item.period}</p>
                <p>{item.details}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="info-panel">
        <h3>Project Interests</h3>
        <ul class="plain-list">
          {profile.interests.map((interest) => <li>{interest}</li>)}
        </ul>
      </section>
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle
      eyebrow="Skills"
      title="Technical toolkit"
      description="Grouped by the areas used across the current portfolio projects."
    />
    <div class="grid two">
      {
        skills.map((group) => (
          <section class="info-panel">
            <h3>{group.group}</h3>
            <div class="tag-list">
              {group.items.map((skill) => <TechTag label={skill} />)}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle eyebrow="Experience" title="Awards and notes" />
    <div class="grid two">
      {
        awards.map((award) => (
          <article class="info-panel">
            <h3>{award.title}</h3>
            <p>{award.issuer} · {award.year}</p>
            <p>{award.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
