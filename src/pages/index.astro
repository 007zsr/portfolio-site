---
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import TechTag from '../components/TechTag.astro';
import profile from '../data/profile.json';
import skills from '../data/skills.json';
import { featuredProjects } from '../lib/projects';
import { siteConfig } from '../lib/site';

const heroStyle = `--hero-image: url('${siteConfig.defaultImage}')`;
const focusTags = skills.flatMap((group) => group.items).slice(0, 10);
---

<Layout>
  <section class="hero" style={heroStyle}>
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Engineering Portfolio</p>
        <h1>{profile.name}</h1>
        <p>{profile.headline}</p>
        <div class="tag-list" aria-label="Technical focus areas">
          {focusTags.map((tag) => <TechTag label={tag} />)}
        </div>
        <div class="hero-actions">
          <a class="button" href="/projects">View projects</a>
          <a class="button secondary" href="/files/resume-placeholder.pdf">Download resume</a>
          <a class="button secondary" href={profile.contact.github}>GitHub</a>
          <a class="button secondary" href="/contact">Contact</a>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <SectionTitle
      eyebrow="Featured"
      title="Selected project work"
      description="A compact view of robotics, communication simulation, computer vision, and game-system prototypes."
    />
    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} compact />)}
    </div>
  </section>
</Layout>
