---
import ProjectDetailPage from '../../page-views/ProjectDetailPage.astro';
import { publicProjects, type Project } from '../../lib/projects';

export function getStaticPaths() {
  return publicProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<ProjectDetailPage locale="zh" project={project} />
