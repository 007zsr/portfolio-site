---
import Layout from '../components/Layout.astro';
import DownloadCard from '../components/DownloadCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import downloads from '../data/downloads.json';
import { getProjectById } from '../lib/projects';

const categories = [
  'Resume / CV',
  'Project Demos',
  'Reports',
  'Presentation Slides',
  'Code Archives',
  'Dataset Samples',
  'Videos',
  'Other Files'
];

const publicDownloads = downloads.filter((download) => download.visibility === 'public');
const groups = categories
  .map((category) => ({
    category,
    items: publicDownloads.filter((download) => download.category === category)
  }))
  .filter((group) => group.items.length > 0);
---

<Layout
  title="Downloads"
  description="Public download center for resume files, project demos, reports, slides, code archives, datasets, and videos."
>
  <section class="page-section">
    <SectionTitle
      eyebrow="Downloads"
      title="Files and external resources"
      description="Public files and external links connected to portfolio projects."
    />

    <div class="download-groups">
      {
        groups.map((group) => (
          <section class="download-group">
            <h2>{group.category}</h2>
            <div class="grid">
              {
                group.items.map((download) => (
                  <DownloadCard
                    download={download}
                    project={download.projectId ? getProjectById(download.projectId) : undefined}
                  />
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </section>
</Layout>
