---
import PaperDetailPage from '../../page-views/PaperDetailPage.astro';
import { publicPapers, type Paper } from '../../lib/contentItems';

export function getStaticPaths() {
  return publicPapers.map((paper) => ({
    params: { slug: paper.slug },
    props: { paper }
  }));
}

interface Props {
  paper: Paper;
}

const { paper } = Astro.props;
---

<PaperDetailPage locale="zh" paper={paper} />
