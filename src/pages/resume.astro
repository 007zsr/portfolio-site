---
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import TechTag from '../components/TechTag.astro';
import profile from '../data/profile.json';
import skills from '../data/skills.json';
import awards from '../data/awards.json';
import { featuredProjects } from '../lib/projects';
---

<Layout
  title="Resume"
  description="Online resume for Sirui Zhou with education, project summaries, skills, awards, and contact details."
>
  <section class="page-section">
    <SectionTitle
      eyebrow="Resume"
      title={profile.name}
      description={profile.headline}
    />
    <div class="button-row">
      <a class="button" href="/files/resume-placeholder.pdf">Download PDF</a>
      <a class="button secondary" href="/contact">Contact</a>
    </div>
  </section>

  <section class="page-section tight">
    <div class="grid two">
      <section class="resume-block">
        <h3>Education</h3>
        <ul class="plain-list">
          {
            profile.education.map((item) => (
              <li>
                <strong>{item.school}</strong>
                <p>{item.degree}</p>
                <p>{item.period}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="resume-block">
        <h3>Contact</h3>
        <p>{profile.contact.email}</p>
        <p>{profile.contact.github}</p>
      </section>
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle title="Project summary" />
    <div class="grid two">
      {
        featuredProjects.map((project) => (
          <article class="resume-block">
            <h3>{project.title}</h3>
            <p>{project.role} · {project.year} · {project.status}</p>
            <p>{project.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle title="Skills" />
    <div class="grid two">
      {
        skills.map((group) => (
          <section class="resume-block">
            <h3>{group.group}</h3>
            <div class="tag-list">
              {group.items.map((skill) => <TechTag label={skill} />)}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <section class="page-section tight">
    <SectionTitle title="Awards and notes" />
    <div class="grid two">
      {
        awards.map((award) => (
          <article class="resume-block">
            <h3>{award.title}</h3>
            <p>{award.issuer} · {award.year}</p>
            <p>{award.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
