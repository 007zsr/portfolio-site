---
import VideoDetailPage from '../../page-views/VideoDetailPage.astro';
import { publicVideos, type Video } from '../../lib/contentItems';

export function getStaticPaths() {
  return publicVideos.map((video) => ({
    params: { slug: video.slug },
    props: { video }
  }));
}

interface Props {
  video: Video;
}

const { video } = Astro.props;
---

<VideoDetailPage locale="zh" video={video} />
